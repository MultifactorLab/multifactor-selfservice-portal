@model MultiFactor.SelfService.Linux.Portal.ViewModels.ChangePasswordViewModel

@{
    ViewData["Title"] = Localizer["Title"];
    ViewBag.UseAuthBackground = true;
}

<div class="login login-view password-change-view">
    <div class="login-header-plate">
        <img src="~/@Settings.CompanySettings.LogoUrl" alt="logo" class="login-header-logo" />
        <span class="login-header-title">@Localizer["Ssp"]</span>
    </div>
    <div class="form-column login-form-card password-change-card">
        <h2 class="login-title password-change-title">@Localizer["Title"]</h2>
        @using (Html.BeginForm("Change", "Password", new { ReturnUrl = "/" }, FormMethod.Post))
        {
        <fieldset>
            @Html.AntiForgeryToken()
            <div class="password-change-description">
                @await Html.PartialAsync("_PasswordRequirementsPartial")
            </div>
            <div class="password-change-validation">
                @Html.ValidationSummary(true)
            </div>
            <div class="form-row login-fields password-change-fields">
                <div class="input login-input password-change-input">
                    @Html.PasswordFor(m => m.Password, new { placeholder = Localizer.GetString("CurrentPassword"), autocomplete = "off" })
                    @Html.ValidationMessageFor(m => m.Password)
                </div>
                <div class="input login-input password-change-input">
                    @Html.PasswordFor(m => m.NewPassword, new { placeholder = Localizer.GetString("NewPassword"), autocomplete = "off" })
                    @Html.ValidationMessageFor(m => m.NewPassword)
                </div>
                <div class="input login-input password-change-input">
                    @Html.PasswordFor(m => m.NewPasswordAgain, new { placeholder = Localizer.GetString("ConfirmPassword"), autocomplete = "off" })
                    @Html.ValidationMessageFor(m => m.NewPasswordAgain)
                </div>
            </div>
            <div class="form-row password-change-submit-row">
                <input type="submit" class="btn-primary w-100" value="@Localizer["Submit"]" />
            </div>
        </fieldset>
        }
    </div>
</div>