@model MultiFactor.SelfService.Linux.Portal.ViewModels.ShowcaseViewModel
@{
    ViewBag.Home = true;
}

@if (@ShowcaseSettings.CurrentValue != null && @ShowcaseSettings.CurrentValue.Enabled)
{
    <div class="apps-header">
        <div class="apps-header-top">
            <strong class="apps-logo">
                <img src="~/@Settings.CompanySettings.LogoUrl" />
            </strong>
            <div class="apps-header-actions">
                @Html.ActionLink(Localizer["Configure2FA"].Value, "Index", "Configure2Fa", new { }, new { target = "_blank", @class = "btn-header" })
                @if (Model.Profile.EnablePasswordManagement)
                {
                    <a href="~/password/change" class="btn-header">@Localizer["ChangePassword"]</a>
                }
                @if (Model.Profile.EnableExchangeActiveSyncDevicesManagement)
                {
                    <a href="~/ExchangeActiveSyncDevices" class="btn-header">@Localizer["ManageActiveSyncDevices"]</a>
                }
                <a href="~/account/logout" class="btn-header btn-header-exit">@Localizer["Exit"]</a>
            </div>
            <div class="apps-header-user">
                <div class="user-avatar">
                    <span class="avatar-letter">@(Model?.Profile?.Name?[0] ?? Model?.Profile?.Identity?[0])</span>
                </div>
                <span class="user-name">@(Model?.Profile?.Name ?? Model?.Profile?.Identity)</span>
                <a href="~/account/logout" class="btn-exit">
                    <svg width="24" height="24" viewBox="0 0 15.5 17.5" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false">
                        <path d="M10.75 0.75H0.75V14.75C0.75 15.2804 0.960714 15.7891 1.33579 16.1642C1.71086 16.5393 2.21957 16.75 2.75 16.75H10.75M11.75 11.75L14.75 8.75M14.75 8.75L11.75 5.75M14.75 8.75H4.75"
                              stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                </a>
            </div>
        </div>
    </div>   
<div class="apps-container">
    <div class="apps-content">
        <div class="apps-title-section">
            <h2 class="apps-title">Доступные приложения</h2>
        </div>

        <div class="apps-grid">
            @if (Model?.ShowcaseLinks != null && Model.ShowcaseLinks.Count > 0)
            {
                @foreach (var app in Model.ShowcaseLinks)
                {
                    <a href="@app.Url" class="app-card" @(app.OpenInNewTab ? "target=_blank" : "")>
                        <div class="app-card-image">
                            <img src="~/@(string.IsNullOrWhiteSpace(app.Image) ? "content/images/ssoResource.svg" : $"content/images/showcase/{app.Image}")" alt="@app.Title"  />
                        </div>
                        <div class="app-card-title">
                            @app.Title
                        </div>
                    </a>
                }
            }
        </div>
    </div>
</div>
} else
{
    <div class="login">
        <!-- glass header plate inside login container -->
        <div class="login-header-plate">
            <img src="~/@Settings.CompanySettings.LogoUrl" alt="logo" class="login-header-logo" />
            <span class="login-header-title">@Localizer["Ssp"]</span>
        </div>
        <div class="form-column">
            <div class="auth-details">
                <div class="user-avatar-no-sso">
                    <span class="avatar-letter">@(Model?.Profile?.Name?[0] ?? Model?.Profile?.Identity?[0])</span>
                </div>
                <div class="auth-username">
                    <p>@Localizer["Greetings"]</p>
                    <h2 class="user-login">@(Model.Profile.Name ?? Model.Profile.Identity)</h2>
                </div>
            </div>
            <ul class="action">
                <li><a target ="_blank" href="~/Configure2Fa">
                    <input type="button" class="w-100 btn-primary" value="@Localizer["Configure2FA"]" /></a>
                </li>
                @if (Model.Profile.EnablePasswordManagement)
                {
                    <li><a href="~/password/change">
                        <input type="button" class="w-100 btn-primary" value="@Localizer["ChangePassword"]" />
                    </a></li>
                }
                @if (Model.Profile.EnableExchangeActiveSyncDevicesManagement)
                {
                    <li><a href="~/ExchangeActiveSyncDevices">
                        <input type="button" class="w-100 btn-primary" value="@Localizer["ManageActiveSyncDevices"]" />
                    </a></li>
                }
                <li><a href="~/account/logout" class="btn btn-secondary">@Localizer["Exit"]</a></li>
            </ul>
        </div>
    </div>

}
